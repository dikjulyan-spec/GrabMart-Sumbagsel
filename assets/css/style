:root{
  --grab:#00B14F;--grab-2:#008C3E;--ink:#10271d;--muted:#587367;--soft:#f3fbf5;--soft-2:#e7f6eb;--line:#d4ead9;--white:#fff;--dark:#06351f;--shadow:0 18px 60px rgba(0,80,40,.12);--radius:24px;--max:1180px;--nav:76px
}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{font-family:'Plus Jakarta Sans',system-ui,-apple-system,Segoe UI,sans-serif;background:#fff;color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}a{text-decoration:none;color:inherit}img{max-width:100%;display:block}button,input{font:inherit}.container{max-width:var(--max);margin:auto;padding:0 24px}.chip{display:inline-flex;gap:8px;align-items:center;background:var(--soft);border:1px solid var(--line);color:var(--grab-2);font-size:12px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;padding:7px 13px;border-radius:999px}.dot{width:8px;height:8px;background:var(--grab);border-radius:50%;box-shadow:0 0 0 6px rgba(0,177,79,.12)}.section{padding:96px 0}.section.soft{background:var(--soft)}.section.dark{background:radial-gradient(circle at top left,rgba(255,255,255,.16),transparent 30%),linear-gradient(135deg,#04311d,#006d35 60%,#00a64a);color:#fff}.section-head{max-width:680px;margin:0 auto 42px;text-align:center}.section-head h2{font-size:clamp(30px,4vw,48px);line-height:1.08;letter-spacing:-.04em;margin:14px 0 12px}.section-head p{color:var(--muted);font-weight:600}.dark .section-head p{color:rgba(255,255,255,.78)}.g{color:var(--grab)}
.nav{position:fixed;inset:0 0 auto;height:var(--nav);z-index:1000;background:rgba(255,255,255,.86);backdrop-filter:blur(18px);border-bottom:1px solid rgba(212,234,217,.8);transition:.25s}.nav.scrolled{height:64px;box-shadow:0 10px 35px rgba(0,80,40,.08)}.nav-inner{height:100%;max-width:var(--max);margin:auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;gap:20px}.brand img{height:42px;width:auto}.nav-links{display:flex;gap:26px;align-items:center;font-size:14px;font-weight:800;color:#315545}.nav-links a{opacity:.88}.nav-links a:hover{color:var(--grab)}.nav-actions{display:flex;align-items:center;gap:10px}.btn{display:inline-flex;align-items:center;justify-content:center;gap:9px;border-radius:14px;padding:13px 18px;font-weight:900;font-size:14px;border:1px solid transparent;transition:.22s;cursor:pointer}.btn.primary{background:var(--grab);color:#fff;box-shadow:0 10px 25px rgba(0,177,79,.25)}.btn.primary:hover{background:var(--grab-2);transform:translateY(-2px)}.btn.ghost{background:#fff;color:var(--grab-2);border-color:var(--line)}.btn.ghost:hover{border-color:var(--grab);transform:translateY(-2px)}.menu-btn{display:none;background:#fff;border:1px solid var(--line);border-radius:12px;width:44px;height:44px;font-size:20px}.mobile-menu{display:none;position:fixed;inset:var(--nav) 0 auto;background:#fff;border-bottom:1px solid var(--line);z-index:999;padding:18px 24px;box-shadow:0 24px 60px rgba(0,0,0,.08)}.mobile-menu a{display:block;padding:13px 0;font-weight:900;color:#244936;border-bottom:1px solid #edf6ef}.mobile-menu .btn{margin-top:14px;width:100%}
.hero{min-height:100vh;padding:calc(var(--nav) + 66px) 0 64px;position:relative;overflow:hidden;background:linear-gradient(155deg,#f5fff7 0%,#fff 48%,#e6f8ec 100%)}.hero:before{content:'';position:absolute;width:740px;height:740px;border-radius:50%;right:-260px;top:90px;background:radial-gradient(circle,rgba(0,177,79,.22),transparent 62%)}.hero-grid{position:relative;z-index:1;display:grid;grid-template-columns:1.02fr .98fr;gap:54px;align-items:center}.hero h1{font-size:clamp(42px,6vw,76px);line-height:.98;letter-spacing:-.06em;margin:18px 0 22px}.hero p{font-size:18px;color:#3f6352;font-weight:600;max-width:560px}.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;margin:30px 0}.proof{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;max-width:620px}.proof-card{background:rgba(255,255,255,.78);border:1px solid var(--line);border-radius:18px;padding:16px;box-shadow:0 8px 30px rgba(0,80,40,.06)}.proof-card b{display:block;font-size:22px;color:var(--grab);line-height:1}.proof-card span{font-size:12px;color:var(--muted);font-weight:800}.hero-art{position:relative}.hero-art img{filter:drop-shadow(0 26px 55px rgba(0,80,40,.18));animation:float 5s ease-in-out infinite}.mini-panel{position:absolute;left:8px;bottom:28px;background:#fff;border:1px solid var(--line);box-shadow:var(--shadow);border-radius:20px;padding:16px;display:flex;align-items:center;gap:12px;font-weight:900}.mini-panel small{display:block;color:var(--muted);font-weight:700}@keyframes float{50%{transform:translateY(-12px)}}
.trust{padding:20px 0;background:var(--dark);color:#fff}.trust-row{display:flex;align-items:center;justify-content:center;gap:24px;flex-wrap:wrap;font-size:13px;font-weight:800;color:rgba(255,255,255,.72)}.trust-row b{color:#fff}.benefit-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:28px;box-shadow:0 4px 20px rgba(0,80,40,.04);transition:.24s}.card:hover{transform:translateY(-5px);box-shadow:var(--shadow);border-color:rgba(0,177,79,.36)}.icon{width:48px;height:48px;border-radius:16px;background:var(--soft-2);color:var(--grab-2);display:grid;place-items:center;margin-bottom:18px}.card h3{font-size:19px;letter-spacing:-.02em;margin-bottom:8px}.card p{font-size:14px;color:var(--muted);font-weight:600}.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.step{position:relative;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:32px}.step-num{width:44px;height:44px;border-radius:14px;background:var(--grab);color:#fff;display:grid;place-items:center;font-weight:900;margin-bottom:18px}.step h3{font-size:21px;margin-bottom:8px}.step p{color:var(--muted);font-weight:600;font-size:14px}.merchant-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.merchant-card{background:#fff;border:1px solid var(--line);border-radius:22px;overflow:hidden;box-shadow:0 6px 28px rgba(0,80,40,.06);transition:.24s}.merchant-card:hover{transform:translateY(-6px);box-shadow:var(--shadow)}.merchant-img{aspect-ratio:9/16;background:#153d2a;position:relative;overflow:hidden}.merchant-img img{width:100%;height:100%;object-fit:cover}.badge{position:absolute;top:12px;left:12px;background:var(--grab);color:#fff;border-radius:999px;padding:5px 10px;font-size:11px;font-weight:900}.merchant-body{padding:16px}.merchant-body h3{font-size:15px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.merchant-body p{font-size:12px;color:var(--muted);font-weight:700;margin:4px 0 12px}.merchant-link{display:flex;justify-content:center;background:var(--soft);border:1px solid var(--line);border-radius:12px;padding:9px;color:var(--grab-2);font-size:12px;font-weight:900}.testimonial-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.quote{background:#fff;color:var(--ink);border-radius:var(--radius);padding:28px}.quote .stars{color:#f5a400;letter-spacing:2px;margin-bottom:12px}.quote p{font-size:15px;color:#385a4a;font-weight:600}.quote b{display:block;margin-top:18px}.cta-band{background:#fff;color:var(--ink);border-radius:32px;padding:42px;display:grid;grid-template-columns:1fr auto;gap:22px;align-items:center;box-shadow:0 30px 80px rgba(0,0,0,.18)}.cta-band h2{font-size:clamp(28px,4vw,46px);letter-spacing:-.04em;line-height:1.08}.cta-band p{color:var(--muted);font-weight:600;margin-top:8px}.faq{max-width:860px;margin:auto;display:grid;gap:12px}.faq-item{background:#fff;border:1px solid var(--line);border-radius:18px;overflow:hidden}.faq-q{width:100%;border:0;background:transparent;text-align:left;padding:20px 22px;font-weight:900;color:var(--ink);display:flex;justify-content:space-between;gap:20px;cursor:pointer}.faq-a{display:none;padding:0 22px 20px;color:var(--muted);font-weight:600}.faq-item.open .faq-a{display:block}.contact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.contact-card{background:#fff;border:1px solid var(--line);border-radius:22px;padding:24px;text-align:center}.contact-card b{display:block}.contact-card span{color:var(--grab);font-weight:900;font-size:15px}.footer{background:#052a19;color:#fff;padding:48px 0}.footer-grid{display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:32px}.footer img{height:42px;width:max-content;margin-bottom:14px}.footer p,.footer a{color:rgba(255,255,255,.66);font-weight:700;font-size:14px}.footer a{display:block;margin:8px 0}.footer h4{margin-bottom:12px}.wa{position:fixed;right:22px;bottom:22px;z-index:1001}.wa-bubble{display:none;width:min(330px,calc(100vw - 44px));background:#fff;border:1px solid var(--line);border-radius:24px;padding:18px;box-shadow:var(--shadow);margin-bottom:12px}.wa-bubble.show{display:block}.wa-title{font-weight:900;margin-bottom:4px}.wa-sub{color:var(--muted);font-size:13px;font-weight:700;margin-bottom:12px}.wa-options{display:grid;gap:8px}.wa-options button{border:1px solid var(--line);background:var(--soft);border-radius:12px;padding:10px 12px;text-align:left;font-weight:900;color:#204631;cursor:pointer}.wa-btn{width:62px;height:62px;border-radius:50%;border:0;background:#25D366;color:#fff;display:grid;place-items:center;box-shadow:0 12px 28px rgba(37,211,102,.36);cursor:pointer;margin-left:auto}.empty{grid-column:1/-1;text-align:center;color:var(--muted);font-weight:800;padding:34px;background:#fff;border:1px dashed var(--line);border-radius:20px}.reveal{opacity:0;transform:translateY(24px);transition:.7s}.reveal.show{opacity:1;transform:none}
@media(max-width:980px){.nav-links{display:none}.menu-btn{display:block}.hero-grid{grid-template-columns:1fr;text-align:center}.hero p,.proof{margin-left:auto;margin-right:auto}.hero-ctas{justify-content:center}.hero-art{max-width:560px;margin:auto}.benefit-grid,.merchant-grid{grid-template-columns:repeat(2,1fr)}.steps,.testimonial-grid,.contact-grid,.footer-grid{grid-template-columns:1fr}.cta-band{grid-template-columns:1fr;text-align:center}.cta-band .btn{width:100%}}
@media(max-width:620px){:root{--nav:64px}.container{padding:0 18px}.section{padding:68px 0}.brand img{height:36px}.nav .btn.primary{display:none}.hero{padding-top:calc(var(--nav) + 38px)}.hero h1{font-size:40px}.hero p{font-size:15px}.hero-ctas .btn{width:100%}.proof{grid-template-columns:1fr}.benefit-grid,.merchant-grid{grid-template-columns:1fr}.hero-art{display:none}.contact-grid{grid-template-columns:1fr}.footer{padding-bottom:90px}}
